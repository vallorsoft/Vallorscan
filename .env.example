# --- Vallorscan konfiguráció ---

# Szerver port
PORT=4000

# SQLite adatbázis fájl elérési útja (a központi adatbázis)
DB_PATH=./data/vallorscan.sqlite

# Belépési token(ek) – vesszővel elválasztva "név:token" formában.
# Minden telefon ezzel a tokennel hitelesít. Üres = nyitott (csak helyi teszthez!).
# Példa: "iroda:s3cret-token-1,sofor1:token-2"
AUTH_TOKENS=

# --- AI (Gemini) ---
# Ha üres, a rendszer determinisztikus regex-fallbackkel dolgozik (kulcs nélkül is fut).
GEMINI_API_KEY=
# Modellek sorrendben (ingyenes keret). Ha az egyik túlterhelt (503) vagy elfogy
# a kerete (429), automatikusan a következőre vált. Üresen az alapértelmezett lista fut.
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite

# Cég-összevonási hasonlósági küszöb (0..1). E fölött "lehetséges duplikátum" javaslat.
COMPANY_MATCH_THRESHOLD=0.82
