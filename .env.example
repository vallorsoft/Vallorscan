# --- Vallorscan konfiguráció ---

# Szerver port
PORT=4000

# SQLite adatbázis fájl elérési útja (a központi adatbázis)
DB_PATH=./data/vallorscan.sqlite

# --- Bejelentkezés / superadmin ---
# Az első indításkor automatikusan létrejön egy superadmin. Ha itt megadod,
# ezekkel jön létre (egyébként generált jelszót ír a konzolra, és belépéskor cserélni kell).
SUPERADMIN_EMAIL=vallorsoft@gmail.com
SUPERADMIN_PASSWORD=

# --- AI (Gemini) ---
# Ha üres, a rendszer determinisztikus regex-fallbackkel dolgozik (kulcs nélkül is fut).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Cég-összevonási hasonlósági küszöb (0..1). E fölött "lehetséges duplikátum" javaslat.
COMPANY_MATCH_THRESHOLD=0.82
